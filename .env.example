# Copy to .env and adjust. All config is via env (12-factor) so the app stays cloud-agnostic.

ENVIRONMENT=development

# ClickHouse (analytics)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=spin2note

# PostgreSQL (app state; shared with Supabase Auth)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spin2note

# Redis (parse pipeline queue)
REDIS_URL=redis://localhost:6379/0

# MinIO (raw HH staging)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_RAW=raw-hh

# Supabase Auth (self-hosted GoTrue)
SUPABASE_JWKS_URL=http://localhost:9999/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
# For local dev GoTrue uses an HS256 shared secret; set the same value here and in compose.
SUPABASE_JWT_SECRET=super-secret-jwt-token-change-me

# ClickHouse batching (hard rule: never single-row inserts)
BATCH_MAX_ROWS=1000
BATCH_MAX_INTERVAL_SECONDS=1.0
